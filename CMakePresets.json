{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default",
      "description": "Configure with the default generator.",
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "xcode",
      "displayName": "Xcode",
      "description": "Generate an Xcode project.",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build-xcode"
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "xcode-release",
      "configurePreset": "xcode",
      "configuration": "Release"
    }
  ]
}
